---
import { SMART_CALENDAR_CONFIG } from '../config';

const { enabled, showLunar, showSolarTerms, showHolidays, events, countdowns } = SMART_CALENDAR_CONFIG;

// 获取当前日期
const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();
const currentDate = now.getDate();
const currentDay = now.getDay();

// 星期名称
const weekDays = ['日', '一', '二', '三', '四', '五', '六'];

// 月份名称
const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月'];

// 获取当月天数
const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();

// 获取当月第一天是星期几
const firstDayOfMonth = new Date(currentYear, currentMonth, 1).getDay();

// 简单的农历数据（简化版）
const lunarDays = ['初一', '初二', '初三', '初四', '初五', '初六', '初七', '初八', '初九', '初十',
  '十一', '十二', '十三', '十四', '十五', '十六', '十七', '十八', '十九', '二十',
  '廿一', '廿二', '廿三', '廿四', '廿五', '廿六', '廿七', '廿八', '廿九', '三十'];

// 节气数据（简化版）
const solarTerms = [
  '小寒', '大寒', '立春', '雨水', '惊蛰', '春分',
  '清明', '谷雨', '立夏', '小满', '芒种', '夏至',
  '小暑', '大暑', '立秋', '处暑', '白露', '秋分',
  '寒露', '霜降', '立冬', '小雪', '大雪', '冬至'
];

// 获取节气日期（简化算法）
function getSolarTermDate(year: number, termIndex: number): number {
  const termDays = [6, 20, 4, 19, 6, 21, 5, 20, 6, 21, 6, 21, 7, 23, 8, 23, 8, 23, 9, 24, 8, 22, 7, 22];
  return termDays[termIndex] || 1;
}

// 获取当前节气
function getCurrentSolarTerm(month: number, date: number): string | null {
  const termIndex = month * 2;
  const termDate1 = getSolarTermDate(currentYear, termIndex);
  const termDate2 = getSolarTermDate(currentYear, termIndex + 1);
  
  if (date === termDate1) return solarTerms[termIndex];
  if (date === termDate2) return solarTerms[termIndex + 1];
  return null;
}

// 获取节日
function getHoliday(month: number, date: number): string | null {
  const monthStr = String(month + 1).padStart(2, '0');
  const dateStr = String(date).padStart(2, '0');
  const event = events.find(e => e.date === `${monthStr}-${dateStr}`);
  return event?.name || null;
}

// 生成日历数据
const calendarDays = [];
for (let i = 0; i < firstDayOfMonth; i++) {
  calendarDays.push(null); // 空白天数
}
for (let i = 1; i <= daysInMonth; i++) {
  calendarDays.push(i);
}

// 获取下一个倒计时
const nextCountdown = countdowns?.length > 0 ? countdowns[0] : null;
---

{enabled && (
  <div class="card smart-calendar-widget">
    <div class="card-header">
      <p class="card-header-title">
        <i class="fas fa-calendar-alt mr-2"></i>
        智能日历
      </p>
    </div>
    <div class="card-content">
      {/* 当前日期显示 */}
      <div class="current-date">
        <div class="date-main">
          <span class="date-day">{currentDate}</span>
          <div class="date-info">
            <span class="date-week">星期{weekDays[currentDay]}</span>
            <span class="date-month">{currentYear}年{monthNames[currentMonth]}</span>
          </div>
        </div>
        {showLunar && (
          <div class="lunar-date">
            <span class="lunar-text">农历{lunarDays[(currentDate - 1) % 30]}</span>
          </div>
        )}
      </div>

      {/* 节气/节日显示 */}
      {(showSolarTerms || showHolidays) && (
        <div class="special-dates">
          {showSolarTerms && getCurrentSolarTerm(currentMonth, currentDate) && (
            <span class="solar-term">
              <i class="fas fa-leaf"></i>
              {getCurrentSolarTerm(currentMonth, currentDate)}
            </span>
          )}
          {showHolidays && getHoliday(currentMonth, currentDate) && (
            <span class="holiday">
              <i class="fas fa-star"></i>
              {getHoliday(currentMonth, currentDate)}
            </span>
          )}
        </div>
      )}

      {/* 月历 */}
      <div class="calendar-grid">
        <div class="week-header">
          {weekDays.map(day => (
            <span class={`week-day ${day === '日' || day === '六' ? 'weekend' : ''}`}>{day}</span>
          ))}
        </div>
        <div class="days-grid">
          {calendarDays.map((day, index) => (
            <div class={`day-cell ${day === currentDate ? 'today' : ''} ${day === null ? 'empty' : ''}`}>
              {day && (
                <>
                  <span class="day-number">{day}</span>
                  {showLunar && day <= 30 && (
                    <span class="lunar-text-small">{lunarDays[(day - 1) % 30]}</span>
                  )}
                </>
              )}
            </div>
          ))}
        </div>
      </div>

      {/* 倒计时 */}
      {nextCountdown && (
        <div class="countdown-section" data-target={nextCountdown.targetDate} data-id={nextCountdown.id}>
          <div class="countdown-header">
            <i class={`fas ${nextCountdown.icon}`}></i>
            <span>{nextCountdown.title}</span>
          </div>
          <div class="countdown-display">
            <div class="countdown-unit">
              <span class="countdown-value" data-unit="days">--</span>
              <span class="countdown-label">天</span>
            </div>
            <div class="countdown-unit">
              <span class="countdown-value" data-unit="hours">--</span>
              <span class="countdown-label">时</span>
            </div>
            <div class="countdown-unit">
              <span class="countdown-value" data-unit="minutes">--</span>
              <span class="countdown-label">分</span>
            </div>
            <div class="countdown-unit">
              <span class="countdown-value" data-unit="seconds">--</span>
              <span class="countdown-label">秒</span>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
)}

<script>
  (function() {
    function updateCountdown(element: HTMLElement) {
      const targetDate = new Date(element.dataset.target || '');
      const now = new Date();
      const diff = targetDate.getTime() - now.getTime();
      
      if (diff <= 0) {
        element.querySelectorAll('.countdown-value').forEach(el => {
          (el as HTMLElement).textContent = '00';
        });
        return;
      }
      
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);
      
      const daysEl = element.querySelector('[data-unit="days"]');
      const hoursEl = element.querySelector('[data-unit="hours"]');
      const minutesEl = element.querySelector('[data-unit="minutes"]');
      const secondsEl = element.querySelector('[data-unit="seconds"]');
      
      if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
      if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
      if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
      if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
    }
    
    const countdownSection = document.querySelector('.countdown-section') as HTMLElement;
    if (countdownSection) {
      updateCountdown(countdownSection);
      setInterval(() => updateCountdown(countdownSection), 1000);
    }
  })();
</script>

<style>
  .smart-calendar-widget {
    margin-bottom: 2rem;
  }

  .current-date {
    text-align: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }

  .date-main {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .date-day {
    font-size: 3rem;
    font-weight: 700;
    color: var(--primary);
    line-height: 1;
  }

  .date-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
  }

  .date-week {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-strong);
  }

  .date-month {
    font-size: 0.9rem;
    color: var(--text-light);
  }

  .lunar-date {
    margin-top: 0.5rem;
  }

  .lunar-text {
    font-size: 0.9rem;
    color: var(--text-light);
    background: var(--tag-bg);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius);
  }

  .special-dates {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .solar-term, .holiday {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .solar-term {
    background: linear-gradient(135deg, rgba(50, 115, 220, 0.15), rgba(50, 115, 220, 0.05));
    color: var(--primary);
  }

  .holiday {
    background: linear-gradient(135deg, rgba(255, 0, 160, 0.15), rgba(255, 0, 160, 0.05));
    color: #ff00a0;
  }

  [data-theme="dark"] .holiday {
    color: #ff6b9d;
  }

  .calendar-grid {
    margin-bottom: 1rem;
  }

  .week-header {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .week-day {
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-light);
    padding: 0.5rem 0;
  }

  .week-day.weekend {
    color: #ff6b6b;
  }

  .days-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.25rem;
  }

  .day-cell {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    font-size: 0.85rem;
    position: relative;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .day-cell:not(.empty):hover {
    background: var(--hover-bg);
  }

  .day-cell.today {
    background: var(--primary);
    color: #fff;
  }

  .day-cell.today:hover {
    background: var(--primary);
    color: #fff;
    opacity: 0.9;
  }

  .day-cell.today .lunar-text-small {
    color: rgba(255, 255, 255, 0.8);
  }

  .day-cell.today:hover .lunar-text-small {
    color: rgba(255, 255, 255, 0.8);
  }

  .day-cell.empty {
    cursor: default;
  }

  .day-number {
    font-weight: 500;
    line-height: 1.2;
  }

  .lunar-text-small {
    font-size: 0.6rem;
    color: var(--text-lighter);
    line-height: 1;
    margin-top: 0.125rem;
  }

  .countdown-section {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    margin-top: 1rem;
  }

  .countdown-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    color: var(--text-light);
    font-size: 0.9rem;
  }

  .countdown-header i {
    color: var(--primary);
  }

  .countdown-display {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
  }

  .countdown-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 2.5rem;
  }

  .countdown-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--primary);
    font-family: monospace;
    line-height: 1;
    background: var(--tag-bg);
    padding: 0.375rem 0.5rem;
    border-radius: var(--radius);
    min-width: 2rem;
    text-align: center;
  }

  .countdown-label {
    font-size: 0.7rem;
    color: var(--text-light);
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .date-day { font-size: 2.5rem; }
    .countdown-value { font-size: 1rem; min-width: 1.75rem; }
    .countdown-unit { min-width: 2rem; }
  }
</style>