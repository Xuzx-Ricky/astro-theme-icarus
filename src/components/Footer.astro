---
import { SITE, AUTHOR, FOOTER_CONFIG, ANALYTICS_CONFIG, ICP_CONFIG } from '../config';

const currentYear = new Date().getFullYear();
const siteYear = SITE.startYear || currentYear;
const displayYear = siteYear === currentYear ? String(currentYear) : `${siteYear}-${currentYear}`;

// 页脚Logo
let footerLogo = '';
if (FOOTER_CONFIG.logo.text) {
  footerLogo = FOOTER_CONFIG.logo.text;
} else if (FOOTER_CONFIG.logo.image) {
  footerLogo = `<img src="${FOOTER_CONFIG.logo.image}" alt="${SITE.title}" height="28" />`;
} else {
  footerLogo = SITE.title;
}

const hasLinks = Object.keys(FOOTER_CONFIG.links).length > 0;
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      {/* 左侧：Logo 和版权信息 */}
      <div class="footer-left">
        <a class="footer-logo" href="/">
          <Fragment set:html={footerLogo} />
        </a>
        
        <p class="footer-copyright">
          <span>&copy; {displayYear} {AUTHOR.name || SITE.title}</span>
          <span class="footer-divider">|</span>
          <span>Powered by <a href="https://astro.build" target="_blank" rel="noopener">Astro</a></span>
          <span class="footer-divider">|</span>
          <span>Theme <a href="https://github.com/ppoffice/hexo-theme-icarus" target="_blank" rel="noopener">Icarus</a></span>
        </p>
        
        {FOOTER_CONFIG.copyright && (
          <p class="footer-custom" set:html={FOOTER_CONFIG.copyright} />
        )}
        
        {/* 备案信息 */}
        {ICP_CONFIG.enabled && (
          <p class="footer-icp">
            <a 
              href={ICP_CONFIG.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="icp-link"
            >
              <i class="fas fa-shield-alt"></i>
              {ICP_CONFIG.number}
            </a>
            {ICP_CONFIG.police.enabled && (
              <>
                <span class="icp-separator">|</span>
                <a 
                  href={ICP_CONFIG.police.url} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="icp-link"
                >
                  <i class="fas fa-shield-alt"></i>
                  {ICP_CONFIG.police.number}
                </a>
              </>
            )}
          </p>
        )}
        
        {/* 统计信息 - 带错误处理 */}
        {ANALYTICS_CONFIG.busuanzi && (
          <p class="footer-stats" id="busuanzi_stats" style="display: none;">
            <span class="stat-item">
              <i class="fas fa-eye"></i>
              <span id="busuanzi_container_site_pv">
                总访问量 <span id="busuanzi_value_site_pv">--</span>
              </span>
            </span>
            <span class="stat-separator">|</span>
            <span class="stat-item">
              <i class="fas fa-user"></i>
              <span id="busuanzi_container_site_uv">
                访客数 <span id="busuanzi_value_site_uv">--</span>
              </span>
            </span>
          </p>
        )}
      </div>
      
      {/* 右侧：社交链接 */}
      {hasLinks && (
        <div class="footer-right">
          <div class="footer-links">
            {Object.entries(FOOTER_CONFIG.links).map(([name, link]) => (
              <a 
                class="footer-link" 
                href={link.url} 
                target="_blank" 
                rel="noopener" 
                title={name}
              >
                {link.icon ? (
                  <i class={link.icon}></i>
                ) : (
                  name
                )}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</footer>

{/* 卜算子统计脚本 - 带错误处理 */}
{ANALYTICS_CONFIG.busuanzi && (
  <script is:inline>
    (function() {
      // 检查是否被广告拦截器阻止
      function checkBusuanzi() {
        const statsEl = document.getElementById('busuanzi_stats');
        const pvEl = document.getElementById('busuanzi_value_site_pv');
        const uvEl = document.getElementById('busuanzi_value_site_uv');
        
        if (!statsEl) return;
        
        // 等待一段时间检查是否加载成功
        setTimeout(function() {
          const pv = pvEl?.textContent?.trim();
          const uv = uvEl?.textContent?.trim();
          
          // 如果值已加载且不是默认值，显示统计
          if (pv && pv !== '--' && uv && uv !== '--') {
            statsEl.style.display = 'block';
          }
        }, 3000);
      }
      
      // 加载卜算子脚本
      const script = document.createElement('script');
      script.src = 'https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js';
      script.async = true;
      script.onload = checkBusuanzi;
      script.onerror = function() {
        console.warn('Busuanzi failed to load (possibly blocked by ad blocker)');
      };
      document.head.appendChild(script);
    })();
  </script>
)}

<style>
  .footer {
    background: var(--footer-bg);
    border-top: 1px solid var(--border);
    padding: 3rem 1.5rem;
    margin-top: 4rem;
  }
  
  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
  }
  
  .footer-left {
    flex: 1;
    min-width: 280px;
  }
  
  .footer-right {
    display: flex;
    align-items: center;
  }
  
  .footer-logo {
    display: inline-block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-strong);
    margin-bottom: 1rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .footer-logo:hover {
    color: var(--primary);
  }
  
  .footer-logo img {
    vertical-align: middle;
  }
  
  .footer-copyright {
    font-size: 0.9rem;
    color: var(--text-light);
    margin-bottom: 0.75rem;
    line-height: 1.8;
  }
  
  .footer-copyright a {
    color: var(--primary);
    text-decoration: none;
  }
  
  .footer-copyright a:hover {
    text-decoration: underline;
  }
  
  .footer-divider {
    margin: 0 0.5rem;
    color: var(--border);
  }
  
  .footer-custom {
    font-size: 0.85rem;
    color: var(--text-lighter);
    margin-bottom: 0.75rem;
  }
  
  .footer-stats {
    font-size: 0.85rem;
    color: var(--text-light);
    margin-top: 0.75rem;
  }
  
  .stat-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  
  .stat-item i {
    color: var(--primary);
  }
  
  .stat-separator {
    margin: 0 0.75rem;
    color: var(--border);
  }
  
  #busuanzi_value_site_pv,
  #busuanzi_value_site_uv {
    color: var(--primary);
    font-weight: 600;
  }
  
  .footer-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .footer-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius);
    background: var(--tag-bg);
    color: var(--text-light);
    font-size: 1.25rem;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid var(--border);
  }
  
  .footer-link:hover {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
    transform: translateY(-2px);
  }
  
  [data-theme="dark"] .footer-link:hover {
    box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
  }
  
  .footer-icp {
    font-size: 0.85rem;
    color: var(--text-lighter);
    margin-top: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  
  .icp-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .icp-link:hover {
    color: var(--primary);
  }
  
  .icp-link i {
    font-size: 0.8rem;
  }
  
  .icp-separator {
    color: var(--border);
  }
  
  @media (max-width: 768px) {
    .footer {
      padding: 2rem 1rem;
      margin-top: 2rem;
    }
    
    .footer-content {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    
    .footer-left {
      min-width: auto;
    }
    
    .footer-copyright {
      font-size: 0.85rem;
    }
    
    .footer-divider {
      display: block;
      margin: 0.25rem 0;
      opacity: 0;
    }
    
    .footer-stats {
      font-size: 0.8rem;
    }
    
    .stat-separator {
      display: block;
      margin: 0.25rem 0;
      opacity: 0;
    }
  }
</style>
