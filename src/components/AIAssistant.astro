---
import { AI_CONFIG } from '../config';

const { enabled, features } = AI_CONFIG;
---

{enabled && (
  <div class="ai-assistant-widget">
    {/* AI 悬浮按钮 */}
    <button class="ai-trigger" id="aiTrigger" aria-label="AI助手">
      <i class="fas fa-robot"></i>
    </button>
    
    {/* AI 对话框 */}
    <div class="ai-dialog" id="aiDialog">
      <div class="ai-header">
        <div class="ai-title">
          <i class="fas fa-robot"></i>
          <span>AI 助手</span>
        </div>
        <button class="ai-close" id="aiClose" aria-label="关闭">
          <i class="fas fa-times"></i>
        </button>
      </div>
      
      <div class="ai-body">
        {/* 文章摘要 */}
        {features.summary && (
          <div class="ai-section">
            <h4><i class="fas fa-file-alt"></i> 文章摘要</h4>
            <div class="ai-summary" id="aiSummary">
              <p class="ai-placeholder">点击生成文章摘要...</p>
            </div>
            <button class="ai-btn" id="generateSummary">
              <i class="fas fa-magic"></i> 生成摘要
            </button>
          </div>
        )}
        
        {/* 翻译功能 */}
        {features.translation && (
          <div class="ai-section">
            <h4><i class="fas fa-language"></i> 翻译</h4>
            <div class="ai-translation">
              <select id="translateLang" class="ai-select">
                <option value="en">English</option>
                <option value="zh">中文</option>
                <option value="ja">日本語</option>
                <option value="ko">한국어</option>
                <option value="fr">Français</option>
                <option value="de">Deutsch</option>
              </select>
              <button class="ai-btn" id="translateBtn">
                <i class="fas fa-exchange-alt"></i> 翻译页面
              </button>
            </div>
          </div>
        )}
        
        {/* 智能推荐 */}
        {features.recommendation && (
          <div class="ai-section">
            <h4><i class="fas fa-lightbulb"></i> 相关推荐</h4>
            <div class="ai-recommendations" id="aiRecommendations">
              <p class="ai-placeholder">基于当前文章推荐...</p>
            </div>
          </div>
        )}
        
        {/* 聊天对话 */}
        {features.chat && (
          <div class="ai-section ai-chat-section">
            <h4><i class="fas fa-comments"></i> 对话</h4>
            <div class="ai-chat-messages" id="aiChatMessages"></div>
            <div class="ai-chat-input">
              <input type="text" id="aiChatInput" placeholder="输入问题..." />
              <button id="aiChatSend"><i class="fas fa-paper-plane"></i></button>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
)}

<script is:inline define:vars={{ enabled, features }}>
  (function() {
    if (!enabled) return;
    
    const aiTrigger = document.getElementById('aiTrigger');
    const aiDialog = document.getElementById('aiDialog');
    const aiClose = document.getElementById('aiClose');
    
    // 打开/关闭对话框
    aiTrigger?.addEventListener('click', () => {
      aiDialog?.classList.toggle('is-open');
    });
    
    aiClose?.addEventListener('click', () => {
      aiDialog?.classList.remove('is-open');
    });
    
    // 点击外部关闭
    document.addEventListener('click', (e) => {
      if (aiDialog?.classList.contains('is-open') && 
          !aiDialog.contains(e.target) && 
          !aiTrigger.contains(e.target)) {
        aiDialog.classList.remove('is-open');
      }
    });
    
    // 生成摘要功能
    const generateSummaryBtn = document.getElementById('generateSummary');
    const aiSummary = document.getElementById('aiSummary');
    
    generateSummaryBtn?.addEventListener('click', () => {
      const article = document.querySelector('article');
      if (!article) {
        aiSummary.innerHTML = '<p class="ai-error">未找到文章内容</p>';
        return;
      }
      
      // 获取文章内容
      const content = article.textContent || '';
      const sentences = content.split(/[。！？.!?]/).filter(s => s.trim().length > 10);
      
      // 简单的摘要算法（取前3-5句）
      const summarySentences = sentences.slice(0, Math.min(5, sentences.length));
      const summary = summarySentences.join('。') + '。';
      
      aiSummary.innerHTML = `<p>${summary}</p>`;
    });
    
    // 翻译功能
    const translateBtn = document.getElementById('translateBtn');
    translateBtn?.addEventListener('click', () => {
      const lang = document.getElementById('translateLang')?.value || 'en';
      const url = `https://translate.google.com/translate?sl=auto&tl=${lang}&u=${encodeURIComponent(window.location.href)}`;
      window.open(url, '_blank');
    });
    
    // 相关推荐（基于标签）
    const aiRecommendations = document.getElementById('aiRecommendations');
    if (aiRecommendations && features.recommendation) {
      const tags = document.querySelectorAll('.tag');
      if (tags.length > 0) {
        const tagList = Array.from(tags).slice(0, 3).map(t => t.textContent).join(', ');
        aiRecommendations.innerHTML = `<p>当前文章标签: ${tagList}</p><p>查看更多相关文章...</p>`;
      }
    }
  })();
</script>

<style is:global>
  .ai-assistant-widget {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 1000;
  }
  
  .ai-trigger {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), #7c3aed);
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 1.5rem;
    box-shadow: 0 4px 15px rgba(37, 99, 235, 0.4);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .ai-trigger:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.5);
  }
  
  [data-theme="dark"] .ai-trigger {
    background: linear-gradient(135deg, var(--neon-cyan), #a855f7);
    box-shadow: 0 4px 15px rgba(0, 240, 255, 0.3);
  }
  
  .ai-dialog {
    position: absolute;
    bottom: 4.5rem;
    right: 0;
    width: 320px;
    max-height: 500px;
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-hover);
    border: 1px solid var(--border);
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s ease;
  }
  
  .ai-dialog.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  
  .ai-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: linear-gradient(135deg, var(--primary), #7c3aed);
    color: #fff;
  }
  
  [data-theme="dark"] .ai-header {
    background: linear-gradient(135deg, var(--neon-cyan), #a855f7);
  }
  
  .ai-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }
  
  .ai-close {
    background: transparent;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 0.25rem;
    font-size: 1rem;
  }
  
  .ai-body {
    padding: 1rem;
    overflow-y: auto;
    max-height: 400px;
  }
  
  .ai-section {
    margin-bottom: 1.5rem;
  }
  
  .ai-section h4 {
    font-size: 0.9rem;
    color: var(--text-strong);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .ai-section h4 i {
    color: var(--primary);
  }
  
  .ai-placeholder {
    color: var(--text-lighter);
    font-size: 0.85rem;
    font-style: italic;
  }
  
  .ai-error {
    color: #ef4444;
    font-size: 0.85rem;
  }
  
  .ai-summary {
    background: var(--tag-bg);
    padding: 0.75rem;
    border-radius: var(--radius);
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  
  .ai-btn {
    width: 100%;
    padding: 0.625rem;
    background: var(--primary);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  
  .ai-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  
  .ai-select {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card-bg);
    color: var(--text);
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
  }
  
  .ai-translation {
    display: flex;
    flex-direction: column;
  }
  
  .ai-recommendations {
    background: var(--tag-bg);
    padding: 0.75rem;
    border-radius: var(--radius);
    font-size: 0.85rem;
  }
  
  .ai-chat-section {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  
  .ai-chat-messages {
    height: 150px;
    overflow-y: auto;
    background: var(--tag-bg);
    border-radius: var(--radius);
    padding: 0.75rem;
    margin-bottom: 0.75rem;
  }
  
  .ai-chat-input {
    display: flex;
    gap: 0.5rem;
  }
  
  .ai-chat-input input {
    flex: 1;
    padding: 0.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card-bg);
    color: var(--text);
  }
  
  .ai-chat-input button {
    padding: 0.5rem 0.75rem;
    background: var(--primary);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
  }
  
  @media (max-width: 768px) {
    .ai-assistant-widget {
      bottom: 1.5rem;
      right: 1.5rem;
    }
    
    .ai-dialog {
      position: fixed;
      bottom: 5rem;
      right: 1rem;
      left: 1rem;
      width: auto;
    }
  }
</style>