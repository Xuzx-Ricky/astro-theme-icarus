---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ProfileWidget from '../../components/ProfileWidget.astro';
import RecentPosts from '../../components/RecentPosts.astro';
import Categories from '../../components/Categories.astro';
import Comments from '../../components/Comments.astro';
import { getAllPosts } from '../../utils/helpers';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const categories = [...new Set(posts.map(post => post.data.category))];
  
  return categories.map(category => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.params;
const posts = await getAllPosts();
const categoryPosts = posts.filter(post => post.data.category === category);
---

<BaseLayout title={`分类: ${category}`}>
  <div class="container">
    <div class="columns is-variable is-5">
      {/* 左侧边栏 */}
      <div class="column is-3 sidebar-left">
        <div class="sidebar-content">
          <ProfileWidget />
        </div>
      </div>
      
      {/* 主内容区 */}
      <div class="column is-6 main-content">
        <div class="category-header card">
          <div class="card-content has-text-centered">
            <h1 class="title is-3">
              <i class="fas fa-folder-open has-text-primary"></i>
              {category}
            </h1>
            <p class="subtitle is-6">共 {categoryPosts.length} 篇文章</p>
          </div>
        </div>
        
        <div class="posts-container">
          {categoryPosts.map(post => (
            <ArticleCard post={post} />
          ))}
        </div>
        
        {/* 评论区 */}
        <Comments />
      </div>
      
      {/* 右侧边栏 */}
      <div class="column is-3 sidebar-right">
        <div class="sidebar-content">
          <RecentPosts />
          <Categories />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .container {
    padding: 2rem 1rem;
  }
  
  .sidebar-content > * {
    margin-bottom: 2rem;
  }
  
  .category-header {
    margin-bottom: 2rem;
  }
  
  .category-header .title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  
  .category-header .subtitle {
    color: var(--text-light);
  }
  
  .posts-container {
    margin-bottom: 3rem;
  }
  
  @media (max-width: 1024px) {
    .sidebar-left {
      display: none;
    }
    
    .main-content {
      width: 70%;
    }
    
    .sidebar-right {
      width: 30%;
    }
  }
  
  @media (max-width: 768px) {
    .container {
      padding: 1rem;
    }
    
    .main-content,
    .sidebar-right {
      width: 100%;
    }
    
    .sidebar-right {
      display: none;
    }
  }
</style>
