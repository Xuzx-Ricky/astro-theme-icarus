---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileWidget from '../components/ProfileWidget.astro';
import RecentPosts from '../components/RecentPosts.astro';
import Categories from '../components/Categories.astro';
---

<BaseLayout title="搜索" hideSearch={true}>
  <div class="container">
    <div class="columns is-variable is-5">
      {/* 左侧边栏 */}
      <div class="column is-3 sidebar-left">
        <div class="sidebar-content">
          <ProfileWidget />
        </div>
      </div>
      
      {/* 主内容区 */}
      <div class="column is-6 main-content">
        <div class="card search-page">
          <div class="card-header">
            <p class="card-header-title">
              <i class="fas fa-search mr-2"></i>
              搜索文章
            </p>
          </div>
          <div class="card-content">
            <div class="search-box">
              <div class="field has-addons">
                <div class="control is-expanded">
                  <input 
                    type="text" 
                    id="search-input"
                    class="input is-large"
                    placeholder="输入关键词搜索..."
                    autocomplete="off"
                  />
                </div>
                <div class="control">
                  <button id="search-btn" class="button is-primary is-large">
                    <i class="fas fa-search"></i>
                  </button>
                </div>
              </div>
            </div>
            
            <div id="search-stats" class="search-stats"></div>
            <div id="search-results" class="search-results"></div>
          </div>
        </div>
      </div>
      
      {/* 右侧边栏 */}
      <div class="column is-3 sidebar-right">
        <div class="sidebar-content">
          <RecentPosts />
          <Categories />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  let pagefind: any = null;
  let pagefindLoaded = false;
  
  async function loadPagefind() {
    if (pagefindLoaded) return;
    try {
      // @ts-ignore
      pagefind = await import('/pagefind/pagefind.js');
      pagefindLoaded = true;
    } catch (e) {
      console.log('Pagefind not available');
    }
  }
  
  async function performSearch(query: string) {
    const searchStats = document.getElementById('search-stats');
    const searchResults = document.getElementById('search-results');
    
    if (!query.trim()) {
      if (searchStats) searchStats.innerHTML = '';
      if (searchResults) searchResults.innerHTML = '';
      return;
    }
    
    if (!pagefindLoaded) {
      if (searchResults) searchResults.innerHTML = '<div class="search-loading">正在加载搜索...</div>';
      await loadPagefind();
    }
    
    if (!pagefind) {
      if (searchResults) searchResults.innerHTML = '<div class="search-loading">搜索服务暂不可用</div>';
      return;
    }
    
    try {
      const search = await pagefind.search(query);
      
      if (searchStats) {
        searchStats.innerHTML = `找到 <strong>${search.results.length}</strong> 个结果`;
      }
      
      if (search.results.length === 0) {
        if (searchResults) {
          searchResults.innerHTML = `
            <div class="search-empty">
              <i class="fas fa-inbox"></i>
              <p>没有找到相关文章</p>
            </div>
          `;
        }
        return;
      }
      
      const results = await Promise.all(
        search.results.slice(0, 10).map((r: any) => r.data())
      );
      
      if (searchResults) {
        searchResults.innerHTML = results.map((result: any) => `
          <a href="${result.url}" class="search-result-item">
            <div class="result-title">${result.meta.title}</div>
            <div class="result-excerpt">${result.excerpt}</div>
          </a>
        `).join('');
      }
    } catch (err) {
      console.error('Search error:', err);
    }
  }
  
  // 页面加载完成后初始化
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchBtn = document.getElementById('search-btn');
    
    // 延迟加载 pagefind
    setTimeout(loadPagefind, 1000);
    
    searchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value;
      performSearch(query);
    });
    
    searchBtn?.addEventListener('click', () => {
      performSearch(searchInput?.value || '');
    });
    
    searchInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        performSearch(searchInput.value);
      }
    });
    
    // 自动聚焦
    searchInput?.focus();
  });
</script>

<style>
  .container {
    padding: 2rem 1rem;
  }
  
  .sidebar-content > * {
    margin-bottom: 2rem;
  }
  
  .search-page {
    margin-bottom: 2rem;
  }
  
  .search-box {
    margin-bottom: 1.5rem;
  }
  
  .search-stats {
    color: var(--text-light);
    font-size: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  
  .search-stats strong {
    color: var(--primary);
  }
  
  .search-results {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .search-result-item {
    display: block;
    padding: 1.25rem;
    background: var(--tag-bg);
    border-radius: var(--radius-lg);
    color: var(--text);
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid transparent;
  }
  
  .search-result-item:hover {
    background: var(--card-bg);
    border-color: var(--primary);
    transform: translateX(4px);
  }
  
  .result-title {
    font-weight: 600;
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    color: var(--primary);
  }
  
  .result-excerpt {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .search-empty,
  .search-loading {
    text-align: center;
    padding: 4rem;
    color: var(--text-light);
  }
  
  .search-empty i {
    font-size: 4rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }
  
  @media (max-width: 1024px) {
    .sidebar-left {
      display: none;
    }
    
    .main-content {
      width: 70%;
    }
    
    .sidebar-right {
      width: 30%;
    }
  }
  
  @media (max-width: 768px) {
    .container {
      padding: 1rem;
    }
    
    .main-content,
    .sidebar-right {
      width: 100%;
    }
    
    .sidebar-right {
      display: none;
    }
  }
</style>
