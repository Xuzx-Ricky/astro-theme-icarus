---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileWidget from '../components/ProfileWidget.astro';
import RecentPosts from '../components/RecentPosts.astro';
import Comments from '../components/Comments.astro';
import { getAllPosts } from '../utils/helpers';

const posts = await getAllPosts();

// 思考/随想类型的文章（可以按标签筛选）
const thinkingPosts = posts.filter(post => 
  post.data.tags.includes('思考') || 
  post.data.tags.includes('随想') ||
  post.data.category === '思考'
);
---

<BaseLayout title="思考" description="记录日常思考与随想">
  <div class="container">
    <div class="columns is-variable is-5">
      {/* 左侧边栏 */}
      <div class="column is-3 sidebar-left">
        <div class="sidebar-content">
          <ProfileWidget />
        </div>
      </div>
      
      {/* 主内容区 */}
      <div class="column is-6 main-content">
        <div class="card thinking-page">
          <div class="card-header">
            <p class="card-header-title">
              <i class="fas fa-lightbulb mr-2"></i>
              思考与随想
            </p>
          </div>
          <div class="card-content">
            <div class="thinking-intro">
              <p>这里记录我的日常思考、读书笔记、以及对这个世界的观察。</p>
              <p class="thinking-quote">"未经审视的人生不值得过。" —— 苏格拉底</p>
            </div>
            
            {thinkingPosts.length > 0 ? (
              <div class="thinking-list">
                {thinkingPosts.map(post => (
                  <a href={`/blog/${post.slug}/`} class="thinking-item">
                    <span class="thinking-date">{post.data.pubDatetime.toLocaleDateString('zh-CN')}</span>
                    <span class="thinking-title">{post.data.title}</span>
                  </a>
                ))}
              </div>
            ) : (
              <div class="thinking-empty">
                <i class="fas fa-seedling"></i>
                <p>思考的种子正在萌芽...</p>
                <p class="thinking-hint">给文章添加「思考」或「随想」标签，它们会出现在这里。</p>
              </div>
            )}
          </div>
        </div>
        
        <Comments />
      </div>
      
      {/* 右侧边栏 */}
      <div class="column is-3 sidebar-right">
        <div class="sidebar-content">
          <RecentPosts />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .container { padding: 2rem 1rem; max-width: 1400px; }
  .sidebar-content > * { margin-bottom: 2rem; }
  
  .thinking-page { margin-bottom: 2rem; }
  
  .thinking-intro {
    padding: 1.5rem;
    background: var(--tag-bg);
    border-radius: var(--radius-lg);
    margin-bottom: 2rem;
  }
  
  .thinking-intro p {
    margin-bottom: 1rem;
    line-height: 1.8;
  }
  
  .thinking-intro p:last-child { margin-bottom: 0; }
  
  .thinking-quote {
    font-style: italic;
    color: var(--text-light);
    border-left: 3px solid var(--primary);
    padding-left: 1rem;
  }
  
  .thinking-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .thinking-item {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    background: var(--tag-bg);
    border-radius: var(--radius);
    color: var(--text);
    text-decoration: none;
    transition: all 0.2s ease;
    border-left: 3px solid transparent;
  }
  
  .thinking-item:hover {
    background: var(--hover-bg);
    border-left-color: var(--primary);
    transform: translateX(4px);
  }
  
  .thinking-date {
    font-size: 0.85rem;
    color: var(--text-light);
    margin-bottom: 0.5rem;
  }
  
  .thinking-title {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-strong);
  }
  
  .thinking-item:hover .thinking-title {
    color: var(--primary);
  }
  
  .thinking-empty {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-light);
  }
  
  .thinking-empty i {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: var(--primary);
    opacity: 0.5;
  }
  
  .thinking-hint {
    font-size: 0.9rem;
    margin-top: 1rem;
    opacity: 0.7;
  }
  
  @media (max-width: 1024px) {
    .sidebar-left { display: none; }
    .main-content { width: 70%; }
    .sidebar-right { width: 30%; }
  }
  
  @media (max-width: 768px) {
    .container { padding: 1rem; }
    .main-content, .sidebar-right { width: 100%; }
    .sidebar-right { display: none; }
  }
</style>
