---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TOC from '../../components/TOC.astro';
import Comments from '../../components/Comments.astro';
import Copyright from '../../components/Copyright.astro';
import Share from '../../components/Share.astro';
import Donation from '../../components/Donation.astro';
import ProfileWidget from '../../components/ProfileWidget.astro';
import { formatDate, calculateReadingTime, getWordCount } from '../../utils/helpers';

export async function getStaticPaths() {
  const { getCollection } = await import('astro:content');
  const posts = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const readingTime = calculateReadingTime(post.body);
const wordCount = getWordCount(post.body);

// 文章级别配置
const showToc = post.data.toc !== false;
const showComment = post.data.comment !== false;
const showShare = post.data.showShare !== false;
const showDonation = post.data.showDonation === true;
const showSidebar = post.data.showSidebar !== false;
const layout = post.data.layout || 'three-column';
const isSticky = post.data.sticky === true;

// 获取前后文章
const { getCollection } = await import('astro:content');
const posts = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf());
const currentIndex = sortedPosts.findIndex(p => p.slug === post.slug);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

// 根据布局设置列宽
const mainColumnClass = layout === 'two-column' ? 'is-9' : 'is-8';
const leftColumnClass = layout === 'two-column' ? 'is-3' : 'is-3';
const rightColumnClass = layout === 'two-column' ? 'is-0' : 'is-1';
---

<BaseLayout 
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.thumbnail}
  type="article"
  keywords={post.data.tags}
  pubDate={post.data.pubDatetime}
  modDate={post.data.modDatetime}
>
  <div class="container">
    <div class="columns is-variable is-4">
      {/* 左侧边栏 - Profile（不粘性）+ TOC（粘性） */}
      {showSidebar && (
        <div class={`column ${leftColumnClass} sidebar-left`}>
          <ProfileWidget />
          {showToc && <TOC headings={headings} />}
        </div>
      )}
      
      {/* 主内容区 */}
      <div class={`column ${mainColumnClass} main-content`}>
        <article class="card article-page">
          {post.data.thumbnail && (
            <div class="article-hero">
              <img src={post.data.thumbnail} alt={post.data.title} loading="eager" />
            </div>
          )}
          
          <div class="card-content">
            <header class="article-header">
              <h1 class="article-title">
                {isSticky && <span class="sticky-badge"><i class="fas fa-thumbtack"></i> 置顶</span>}
                {post.data.title}
              </h1>
              
              <div class="article-meta">
                <span class="meta-item">
                  <i class="far fa-calendar-alt"></i>
                  {formatDate(post.data.pubDatetime)}
                </span>
                <span class="meta-item">
                  <i class="far fa-folder"></i>
                  <a href={`/categories/${post.data.category}/`}>{post.data.category}</a>
                </span>
                <span class="meta-item">
                  <i class="far fa-clock"></i>
                  {readingTime} 分钟阅读
                </span>
                <span class="meta-item">
                  <i class="far fa-file-word"></i>
                  {wordCount} 字
                </span>
              </div>
              
              <div class="article-tags">
                {post.data.tags.map(tag => (
                  <a href={`/tags/${tag}/`} class="tag">{tag}</a>
                ))}
              </div>
            </header>
            
            <div class="content article-body">
              <Content />
            </div>
            
            {showShare && <Share title={post.data.title} url={Astro.url.href} description={post.data.description} />}
            <Copyright title={post.data.title} pubDatetime={post.data.pubDatetime} updatedDatetime={post.data.modDatetime} slug={post.slug} />
            {showDonation && <Donation />}
          </div>
        </article>
        
        <nav class="post-nav">
          {prevPost && (
            <a href={`/blog/${prevPost.slug}/`} class="post-nav-item post-nav-prev">
              <span class="nav-label"><i class="fas fa-arrow-left"></i> 上一篇</span>
              <span class="nav-title">{prevPost.data.title}</span>
            </a>
          )}
          {nextPost && (
            <a href={`/blog/${nextPost.slug}/`} class="post-nav-item post-nav-next">
              <span class="nav-label">下一篇 <i class="fas fa-arrow-right"></i></span>
              <span class="nav-title">{nextPost.data.title}</span>
            </a>
          )}
        </nav>
        
        {showComment && <Comments />}
      </div>
      
      {/* 右侧边栏 */}
      {layout === 'three-column' && <div class={`column ${rightColumnClass} sidebar-right`}></div>}
    </div>
  </div>
</BaseLayout>

<style>
  .container { padding: 2rem 1rem; max-width: 1400px; }
  
  .article-page { margin-bottom: 2rem; overflow: hidden; }
  
  .article-hero {
    width: 100%;
    max-height: 450px;
    overflow: hidden;
  }
  
  .article-hero img { width: 100%; height: 100%; object-fit: cover; }
  
  .article-header {
    text-align: center;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  
  .article-title {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    line-height: 1.3;
    color: var(--text-strong);
  }
  
  .article-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
    color: var(--text-light);
  }
  
  .meta-item { display: inline-flex; align-items: center; gap: 0.375rem; }
  .meta-item a { color: inherit; }
  .meta-item a:hover { color: var(--primary); }
  
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
  
  .article-tags .tag {
    background: var(--tag-bg);
    color: var(--text-light);
    transition: all 0.2s ease;
    padding: 0.375rem 0.875rem;
  }
  
  .article-tags .tag:hover { background: var(--primary); color: #fff; }
  
  .article-body {
    font-size: 1.125rem;
    line-height: 1.9;
    margin-bottom: 2rem;
  }
  
  .article-body :global(h2) {
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--border);
    color: var(--text-strong);
    font-size: 1.75rem;
  }
  
  .article-body :global(h3) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text-strong);
    font-size: 1.5rem;
  }
  
  .article-body :global(p) { margin-bottom: 1.5rem; }
  .article-body :global(pre) { margin: 1.5rem 0; border-radius: var(--radius-lg); }
  .article-body :global(img) { max-width: 100%; height: auto; border-radius: var(--radius-lg); margin: 1.5rem 0; }
  
  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  
  .post-nav-item {
    flex: 1;
    padding: 1.5rem;
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  
  .post-nav-next { text-align: right; align-items: flex-end; }
  .post-nav-item:hover { border-color: var(--primary); transform: translateY(-2px); box-shadow: var(--shadow-hover); }
  
  .nav-label {
    font-size: 0.85rem;
    color: var(--text-light);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .nav-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text-strong);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .post-nav-item:hover .nav-title { color: var(--primary); }
  
  .sticky-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--primary);
    color: #fff;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.75rem;
    font-weight: 600;
    margin-right: 0.75rem;
    vertical-align: middle;
  }
  
  @media (max-width: 1024px) {
    .sidebar-left { display: none; }
    .main-content { width: 100%; }
    .sidebar-right { display: none; }
  }
  
  @media (max-width: 768px) {
    .container { padding: 1rem; }
    .article-title { font-size: 1.75rem; }
    .article-body { font-size: 1rem; }
    .post-nav { flex-direction: column; }
    .post-nav-next { text-align: left; align-items: flex-start; }
  }
</style>
